generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id            String       @id @default(cuid())
  nombre        String
  telefono      String
  correo        String?
  documento     String?
  fechaRegistro DateTime     @default(now())
  cotizaciones  Cotizacion[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("clientes")
}

model Cotizacion {
  id            String   @id @default(cuid())
  codigo        String   @unique
  estado        Estado   @default(BORRADOR)
  fechaCreacion DateTime @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo          TipoViaje
  origen        String
  destino       String
  fechaSalida   DateTime
  fechaRegreso  DateTime
  aerolinea          String?
  aerolineaIda       String?
  aerolineaRegreso   String?
  plataforma         String?
  horaSalidaIda      String?
  horaLlegadaIda     String?
  horaSalidaRegreso  String?
  horaLlegadaRegreso String?
  tiempoVuelo        String?
  escalas            String?
  tiempoEscala       String?
  hotelNombre        String?
  hotelNoches        Int?
  hotelTipo          String?
  tramos             Json?
  hospedaje          Json?
  mostrarPlanPagos   Boolean @default(true)
  numeroCuotas       Int     @default(3)
  numeroVuelo        String?
  adultos       Int       @default(1)
  menores       Int       @default(0)
  edadesMenores Int[]     @default([])

  servicios  Json
  itinerario Json?

  porcentajeGanancia  Decimal
  utilidadModo        String?   // "porcentaje" | "fijo"
  utilidadFija        Int?      // valor exacto de utilidad si modo = fijo
  valorNetoIndividual Decimal
  valorNetoTotal      Decimal
  gananciaTotal       Decimal
  valorConPorcentaje  Decimal

  planPagos Json

  cobrarIva        Boolean @default(false)
  asistenciaMedica Boolean @default(false)
  observaciones    String?
  notasInternas    String?

  // Propiedad y compartir
  creadoPorId   String?
  creadoPor     Usuario?  @relation(fields: [creadoPorId], references: [id], onDelete: SetNull)
  compartidoCon String[]  @default([])   // ids de usuarios con acceso compartido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cotizaciones")
}

enum Rol {
  ADMIN
  USER
}

model Usuario {
  id           String  @id @default(cuid())
  usuario      String  @unique          // identificador de login (correo o nombre de usuario)
  nombre       String?
  fotoUrl      String?                   // URL de la foto de perfil
  passwordHash String
  rol          Rol     @default(USER)
  mustChangePassword Boolean @default(true)

  // Permisos de páginas (toggles por usuario)
  permInicio       Boolean @default(true)
  permClientes     Boolean @default(true)
  permCotizaciones Boolean @default(true)
  permUsuarios         Boolean @default(false)   // gestión de usuarios (solo admin)
  permModificarEstados Boolean @default(true)    // puede cambiar el estado de cotizaciones

  cotizaciones Cotizacion[]
  bitacora     Bitacora[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

enum Estado {
  BORRADOR
  ENVIADA
  PENDIENTE
  EN_AJUSTE
  APROBADA
  RESERVADA
  PAGANDO
  PAGADA
  VIAJE_REALIZADO
  RECHAZADA
  VENCIDA
  CANCELADA
}

enum TipoViaje {
  NACIONAL
  INTERNACIONAL
}

model Bitacora {
  id          String   @id @default(cuid())
  tipo        String
  descripcion String
  usuarioId   String?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  meta        Json?
  creadoEn    DateTime @default(now())
  @@map("bitacora")
}

model Configuracion {
  clave String @id
  valor String
  @@map("configuracion")
}
